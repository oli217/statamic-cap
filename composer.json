{
    "name": "oliweb/statamic-cap",
    "description": "Statamic addon for Cap CAPTCHA (proof-of-work) integration",
    "type": "statamic-addon",
    "license": "MIT",
    "keywords": ["statamic", "captcha", "cap", "proof-of-work", "spam-protection"],
    "authors": [
        {
            "name": "oliweb",
            "homepage": "https://github.com/oli217"
        }
    ],
    "require": {
        "php": "^8.2",
        "statamic/cms": "^5.0|^6.0",
        "oliweb/laravel-cap": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "StatamicCap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StatamicCap\\Tests\\": "tests/"
        }
    },
    "extra": {
        "statamic": {
            "name": "Cap",
            "slug": "statamic-cap",
            "description": "Cap CAPTCHA (proof-of-work) integration for Statamic forms",
            "developer": "oliweb",
            "url": "https://github.com/oli217/statamic-cap"
        },
        "laravel": {
            "providers": [
                "StatamicCap\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
